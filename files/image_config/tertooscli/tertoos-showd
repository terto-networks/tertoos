#!/usr/bin/env python3
# tertoos-showd — host-side show proxy para o tertoos-cli.
#
# tertoos-cli roda no container mgmt-framework (host netns) e nao tem os
# utilitarios `show`/`vtysh`. Este daemon roda no host, escuta em
# 127.0.0.1:8723 e executa comandos de leitura. Whitelist: `show ...` e
# `vtysh -c "show ..."` (somente leitura — nada de config).
import socket, json, subprocess

ADDR = ('127.0.0.1', 8723)


def allowed(argv):
    if not argv or not isinstance(argv, list):
        return False
    if argv[0] == 'show':
        return True
    if argv[0] == 'vtysh':
        has_c = False
        i = 1
        while i < len(argv):
            if argv[i] == '-c':
                has_c = True
                if i + 1 >= len(argv) or not argv[i + 1].lstrip().startswith('show'):
                    return False
                i += 2
            elif argv[i] == '-d':
                i += 2
            else:
                i += 1
        return has_c
    return False


def handle(conn):
    buf = b''
    while b'\n' not in buf and len(buf) < 65536:
        d = conn.recv(4096)
        if not d:
            break
        buf += d
    try:
        argv = json.loads(buf.split(b'\n', 1)[0].decode('utf-8', 'replace'))
    except Exception:
        conn.sendall(b'tertoos-showd: bad request\n')
        return
    if not allowed(argv):
        conn.sendall(b'tertoos-showd: command not allowed\n')
        return
    try:
        r = subprocess.run(argv, stdout=subprocess.PIPE,
                           stderr=subprocess.STDOUT, timeout=60)
        conn.sendall(r.stdout)
    except Exception as e:
        conn.sendall(('tertoos-showd: ' + str(e) + '\n').encode())


def main():
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind(ADDR)
    s.listen(16)
    while True:
        try:
            conn, _ = s.accept()
        except OSError:
            continue
        try:
            handle(conn)
        except Exception:
            pass
        finally:
            try:
                conn.close()
            except Exception:
                pass


if __name__ == '__main__':
    main()
