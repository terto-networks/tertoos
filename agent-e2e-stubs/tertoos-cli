#!/bin/sh
# Stub tertoos-cli para o sim e2e — aplica as candidate ops do config.apply
# no CONFIG_DB (redis-cfgdb DB4). Conhece o caminho simbólico de fio L2:
#   l2vpn/xconnect/<grupo>/<conn>/<campo>  ->  L2VPN_XCONNECT_GROUP|<grupo>|<conn>  campo
# Outros caminhos: no-op (o sim só exercita L2VPN). begin/commit/abort: no-op.
R="redis-cli -h redis-cfgdb -n 4"
[ "$1" = "candidate" ] || exit 0
op="$2"; shift 2
case "$op" in
  begin|commit|abort) exit 0 ;;
  set)
    path="$1"; val="$2"
    case "$path" in
      l2vpn/xconnect/*/*/*)
        g=$(echo "$path" | cut -d/ -f3)
        c=$(echo "$path" | cut -d/ -f4)
        f=$(echo "$path" | cut -d/ -f5- | tr '_' '-')
        $R HSET "L2VPN_XCONNECT_GROUP|$g|$c" "$f" "$val" >/dev/null ;;
      *) : ;;
    esac ;;
  set-raw)
    $R HSET "$1|$2" "$3" "$4" >/dev/null ;;
  delete)
    path="$1"
    case "$path" in
      l2vpn/xconnect/*/*/*)
        g=$(echo "$path" | cut -d/ -f3); c=$(echo "$path" | cut -d/ -f4)
        f=$(echo "$path" | cut -d/ -f5- | tr '_' '-')
        $R HDEL "L2VPN_XCONNECT_GROUP|$g|$c" "$f" >/dev/null ;;
      l2vpn/xconnect/*/*)
        g=$(echo "$path" | cut -d/ -f3); c=$(echo "$path" | cut -d/ -f4)
        $R DEL "L2VPN_XCONNECT_GROUP|$g|$c" >/dev/null ;;
    esac ;;
  delete-raw)
    $R DEL "$1|$2" >/dev/null ;;
esac
exit 0
